{
  "manifest_version": 3,
  "name": "춘추관 아카이버",
  "version": "0.7.0",
  "default_locale": "ko",
  "description": "__MSG_ext_description__",
  "action": {
    "default_popup": "popup.html",
    "default_title": "춘추관 아카이버",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "cookies", "tabs", "activeTab", "notifications", "alarms", "scripting", "debugger"],
  "optional_host_permissions": ["*://*/*"]
}
