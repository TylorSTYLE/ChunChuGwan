# 춘추관(ChunChuGwan) 환경변수 예시 — 이 파일을 `.env` 로 복사해 사용한다.
#
#   cp .env.example .env      # 그 다음 필요한 줄의 주석(#)을 풀고 값을 채운다
#
# 적용 경로 (둘 다 .env 를 읽는다):
#   • 로컬 실행:  `uv run wccg ...` 가 시작 시 .env 를 자동 로드한다 (python-dotenv,
#                config.py). 현재 작업 디렉토리(또는 그 상위)에서 .env 를 찾는다.
#   • 도커:       docker-compose.yml 의 각 서비스가 `env_file: .env` 로 주입한다
#                (.env 가 없어도 무방 — required:false). `docker run` 은 `--env-file .env`.
#
# 규칙:
#   • 형식은 KEY=값. 값에 따옴표를 두르지 말 것 — compose 의 env_file 은 따옴표를
#     문자 그대로 넣고 python-dotenv 는 벗겨내, 둘이 어긋난다. 공백 없는 값 권장.
#   • 설명은 항상 줄 맨 앞 `#` 로만 단다 — 값 뒤 인라인 주석(KEY=값 # ...)은 compose 의
#     env_file 이 주석째 값에 포함시킬 수 있다.
#   • 실제 환경변수(쉘 export·compose 의 environment:·docker -e)가 .env 보다 우선한다.
#   • 이 파일(.env.example)은 커밋되지만 .env 는 .gitignore 로 제외된다 — 시크릿은
#     반드시 .env 에만 둔다.
#   • 전체 변수·기본값·상세 설명: docs/AUTHENTICATION.md#환경변수
#
# 아래는 모두 주석 처리돼 있다(= 미설정 시 코드 기본값 사용). 필요한 것만 주석을 푼다.


# ── 최초 구동 · 핵심 시크릿 ───────────────────────────────────────────────────

# 최초 구동(사용자 0명) 시 자동 등록할 관리자. 미설정이면 첫 접속의 /setup 에서 만든다.
# 자동 등록 후에는 이 두 줄을 지우는 걸 권장(평문 비번을 환경에 남기지 않도록).
# 비밀번호는 8자 이상.
#WCCG_ADMIN_EMAIL=admin@example.com
#WCCG_ADMIN_PASSWORD=change-this-now

# 외부 사이트 로그인 자격증명(site_credentials) 대칭 암호화 키. 설정해야 그 기능이
# 켜진다. 임의 문자열이며 DB·저장소엔 암호문만 남고 키는 여기에만 둔다. 바꾸면 기존
# 자격증명을 복호화할 수 없다. 강한 키 생성:
#   python -c "import secrets; print(secrets.token_hex(32))"
#WCCG_SECRET_KEY=

# 최초 설정 보호 토큰. 설정 시 /setup 흐름(관리자 생성·복원·이전)이 일치 토큰
# (X-Setup-Token)을 요구 — 셋업 전 외부 노출 인스턴스 선점·SSRF 방지. 셋업이 끝나면
# 무의미해진다. 빈값이면 토큰 없이 셋업 가능.
#WCCG_SETUP_TOKEN=


# ── 외부 노출 · 세션 · 인증 ────────────────────────────────────────────────────

# 외부 노출 시 공개 URL. OIDC redirect_uri 조립, https 면 Secure 쿠키, 패스키
# RP ID/origin 에 쓰인다. HTTPS 종료는 앞단 리버스 프록시가 담당.
#WCCG_PUBLIC_URL=https://archive.example.com

# 로그인 세션 수명(일). 기본 14.
#WCCG_SESSION_TTL_DAYS=14

# 인증 비활성화. off 는 loopback(127.0.0.1) 바인딩일 때만 허용된다 — 외부 노출
# (0.0.0.0)에서는 강제로 on. 도커 대시보드는 내부 0.0.0.0 바인딩이라 항상 on.
#WCCG_AUTH=on

# 대시보드 바인딩 주소. 기본 127.0.0.1(localhost 전용). 로컬에서 외부 노출 테스트
# 시에만 0.0.0.0. (도커 compose 는 dashboard 서비스의 environment: 에서 0.0.0.0 으로
# 고정하므로 컨테이너엔 이 .env 값이 적용되지 않는다 — 로컬 `uv run` 에만 영향.)
#WCCG_HOST=127.0.0.1


# ── OIDC (SSO — Authentik) ────────────────────────────────────────────────────
# 세 값이 모두 채워지면 로그인 화면에 "SSO 로그인" 버튼이 나타난다.
# Redirect URI 는 {WCCG_PUBLIC_URL}/auth/oidc/callback.
#WCCG_OIDC_ISSUER=https://auth.example.com/application/o/chunchugwan
#WCCG_OIDC_CLIENT_ID=
#WCCG_OIDC_CLIENT_SECRET=


# ── SMTP (이메일 초대·본인 인증 발송) ─────────────────────────────────────────
# 시스템 메뉴 저장값이 있으면 그쪽이 우선하고, 없는 항목만 아래로 폴백한다.
# 미설정이면 초대 링크를 화면에 직접 표시한다.
#WCCG_SMTP_HOST=smtp.example.com
#WCCG_SMTP_PORT=587
# WCCG_SMTP_USER 가 없으면 SMTP 인증을 생략한다.
#WCCG_SMTP_USER=
#WCCG_SMTP_PASSWORD=
# 발신자 주소. 미설정 시 WCCG_SMTP_USER 를 쓴다.
#WCCG_SMTP_FROM=
# starttls | ssl | off
#WCCG_SMTP_TLS=starttls
# 초대 링크 수명(일). 기본 7.
#WCCG_INVITE_TTL_DAYS=7


# ── 스케줄러 · 워커 ───────────────────────────────────────────────────────────

# serve 프로세스의 스케줄·크롤 실행. off 면 serve 는 실행하지 않고 worker/cron 이
# 전담한다. (도커 compose 는 dashboard 서비스에서 off 로 고정 — worker 전담.)
#WCCG_SCHEDULER=on

# `wccg worker` 의 동시 진행 크롤(사이트) 수 (1~8). 기본 2.
#WCCG_CRAWL_WORKERS=2


# ── 로그 ──────────────────────────────────────────────────────────────────────

# 설정 시 INFO 이상 로그를 그 경로에 회전 파일로도 남긴다. 프로세스(dashboard/
# worker/cli)별로 다른 파일을 쓸 것(회전 경합 방지). (도커 compose 는 서비스별
# /data/logs/*.log 를 environment: 에서 고정한다.)
#WCCG_LOG_FILE=
# 회전 크기(바이트). 기본 10MB(10485760).
#WCCG_LOG_FILE_MAX_BYTES=10485760
# 보관할 회전 파일 수. 기본 5.
#WCCG_LOG_FILE_BACKUPS=5

# 시스템 로그(/system/logs) DB 보관 한도 행 수. 초과분은 오래된 것부터 자동 정리.
#WCCG_SYSTEM_LOG_MAX_ROWS=20000


# ── 스텔스 캡처 (Cloudflare Turnstile 등 봇 차단 페이지 통과 시도) ─────────────
# 도커에서는 worker 서비스에만 두면 된다(모든 캡처가 worker 에서 실행). 상세·주의는
# docs/AUTHENTICATION.md#환경변수. 데이터센터 IP 평판으로는 통과가 보장되지 않는다.

# playwright(기본) | patchright. patchright 는 Runtime.enable 봇탐지 우회 드롭인
# 엔진(비도커는 `uv sync --extra stealth` 필요, 미설치 시 playwright 로 폴백).
#WCCG_CAPTURE_ENGINE=playwright

# on 이면 헤드풀로 캡처(서버는 Xvfb 필요 — 도커 엔트리포인트가 자동 래핑).
#WCCG_CAPTURE_HEADFUL=off

# chrome 이면 번들 chromium 대신 시스템 real Chrome 사용(TLS/HTTP2 지문이 진짜).
# 도커는 amd64 에만 Chrome 포함 — arm64 는 자동 폴백. 혼용이어도 chrome 으로 둬도 안전.
#WCCG_CAPTURE_CHANNEL=

# on 이면 헤드풀에서도 고정 UA 강제(기본은 헤드풀일 때 해제해 real Chrome 와 일치).
#WCCG_CAPTURE_FORCE_UA=off

# 비상호작용 챌린지(JS 챌린지 등) 자동 통과를 기다리는 최대 시간(초). 기본 25.
#WCCG_CHALLENGE_WAIT_SECONDS=25

# AI 자동 챌린지 해결(B 단계): 자동 통과 대기(A)로도 안 풀린 '양성 게이트'(동의·
# 연령 확인·"계속하려면 클릭")를 비전 LLM(OpenAI 호환)이 스크린샷을 보고 마우스/
# 키보드 입력으로 대신 통과시킨다. 못 풀면 사람 보조(C)로 캐스케이드. 모든 설정
# (활성·base_url·모델·API 키·프롬프트·라운드 등)은 대시보드 시스템 설정에서 관리
# 한다(환경변수 아님). API 키 저장에는 WCCG_SECRET_KEY 가 필요하다(대칭 암호화).

# on 이면 자동으로 못 푼 인터랙티브 챌린지를 관리자가 대시보드에서 직접 풀기(최후
# 수단). 스텔스(patchright/headful)일 때만 의미. worker 가 그 작업을 멈추고 기다린다.
#WCCG_LIVE_CHALLENGE=off

# 라이브 세션에서 사람 입력을 기다리는 하드 타임아웃(초). 기본 300.
#WCCG_LIVE_CHALLENGE_TIMEOUT_SECONDS=300


# ── 저장 위치 · 적재 한도 (고급 — 보통 기본값 유지) ───────────────────────────

# 아카이브 루트 디렉토리(DB·스냅샷·자원). 기본은 실행 위치의 ./archive.
# (도커는 컨테이너 내부 /data/archive 를 쓰므로 바꾸지 말 것 — 볼륨 마운트 경로.)
#WCCG_ROOT=archive

# POST /api/v1/ingest(확장 캡처 업로드) 본문 상한(MB). 기본 50.
#WCCG_INGEST_MAX_MB=50


# ── S3 객체 저장소 백엔드 (선택 — blob 을 로컬 대신 S3 에 저장) ────────────────
#
# 설정해도 "가용성"만 켜질 뿐 활성 백엔드는 바뀌지 않는다 — 실제 전환은 대시보드
# 시스템 화면의 양방향 마이그레이션(또는 첫 구동 setup)으로 한다. 자체 호스팅이면
# MinIO 권장. index.db·캐시는 항상 로컬에 남는다. 상세 → docs/STORAGE.md.
# 아래 값은 플레이스홀더이니 실제 키로 바꿔 주석을 풀 것 (이 파일은 .gitignore 대상).

# MinIO 등 커스텀 엔드포인트. AWS S3 면 비우고 region 을 쓴다.
#WCCG_S3_ENDPOINT_URL=https://minio.example:9000
# 버킷 이름 (필수)
#WCCG_S3_BUCKET=chunchugwan
# 자격증명 (필수). env 전용 — DB·로그에 저장되지 않는다.
#WCCG_S3_ACCESS_KEY_ID=<ACCESS_KEY>
#WCCG_S3_SECRET_ACCESS_KEY=<SECRET_KEY>
# 리전 (기본 us-east-1)
#WCCG_S3_REGION=us-east-1
# path-style 주소 (MinIO 위해 기본 on)
#WCCG_S3_FORCE_PATH_STYLE=on
# 버킷 내 키 프리픽스 (선택)
#WCCG_S3_PREFIX=
# read-through 캐시(blobcache) 용량 상한(MB). 기본 2048.
#WCCG_BLOB_CACHE_MAX_MB=2048
# 로컬↔S3 마이그레이션 동시 전송 워커 수(파일 단위 copy 병렬도). 기본 4, [1,16].
# 네트워크 전송이 느리면 올린다(예: 10). 변경 후 재시작 필요.
#WCCG_S3_MIGRATION_WORKERS=4


# ── 디버그 진단 포트 (develop/테스트 전용 — 릴리스에선 끈다) ─────────────────
# WCCG_DEBUG=on 이면 serve/worker 가 별도 포트(web/debug_server.py)에 진단
# 엔드포인트를 연다 — 내부 상태 조회(읽기) + 안전한 트리거(1회성 캡처·스케줄 1회).
# 시크릿은 노출되지 않지만(원칙 6) 내부 상태가 보이므로 develop 에서만 켤 것.
# 도커로 LAN 노출·핫리로드는 docker-compose.debug.yml / docker-compose.reload.yml 참조.
#WCCG_DEBUG=off
# 컨테이너에서 LAN 으로 노출할 때만 0.0.0.0 (기본 127.0.0.1 — 로컬 전용)
#WCCG_DEBUG_HOST=127.0.0.1
# 진단 포트 (기본 8799)
#WCCG_DEBUG_PORT=8799
# 설정하면 모든 디버그 요청에 X-Debug-Token 헤더를 요구한다 (LAN 노출 시 권장)
#WCCG_DEBUG_TOKEN=


# ── Docker Compose 전용 (춘추관 앱 변수가 아니라 compose/OS 가 읽는다) ─────────

# 컨테이너 타임존 — 1일 주기 스케줄의 실행 시각(HH:MM)이 이 기준. 미설정 시 UTC.
# (compose 는 각 서비스 environment: 에서 Asia/Seoul 로 이미 고정. 로컬 `uv run`
# 에서는 이 값이 그대로 적용된다.)
#TZ=Asia/Seoul

# develop(테스트) 이미지로 띄울 때 매번 -f 를 넘기지 않으려면 주석 해제.
#COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# 디버그 진단 포트까지 노출하려면 debug 오버레이를 이어 붙인다(develop 전용).
# 핫리로드까지 쓰려면 :docker-compose.reload.yml 도 덧붙인다.
#COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml:docker-compose.debug.yml
